{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true
  },
  "include": ["channels/**/*.ts", "orchestrator/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "worktrees"]
}
